# =============================================================================
# Local development environment
# =============================================================================
# Copy this file to `.env` and fill in your own keys. The Express server reads
# these at startup (see server.ts). There is NO Lovable-hosted AI dependency —
# all AI calls go directly to the providers below from your own machine.
#
# Required for AI generation:
#   1. Get a free Gemini API key from https://aistudio.google.com/
#   2. Paste it as GEMINI_API_KEY below
#   3. Restart `npm run dev`
#
# Without GEMINI_API_KEY (and no OPENROUTER_API_KEY fallback), the UI still
# loads but every /api/ai/* endpoint returns HTTP 503 AI_NOT_CONFIGURED.
# =============================================================================

# Required (unless OPENROUTER_API_KEY is provided as the primary).
GEMINI_API_KEY=your_gemini_api_key_here

# Optional fallback / primary provider — https://openrouter.ai/
# If set, OpenRouter is tried first and Gemini is used as the fallback.
OPENROUTER_API_KEY=

# Optional. Restrict CORS in production (comma-separated origins).
# Ignored when NODE_ENV !== "production".
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional. Set to "production" when deploying. In production, missing
# GEMINI_API_KEY is a fatal startup error.
NODE_ENV=development
