    "helmet": "^8.1.0",
    "idb-keyval": "^6.2.2",
    "json2csv": "^6.0.0-alpha.2",
    "lucide-react": "^0.546.0",
    "lz-string": "^1.5.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "react": "^19.0.1",
